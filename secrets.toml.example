# ============================================
# OPCIONAL — Este arquivo é 100% opcional!
# Todas as configurações podem ser preenchidas
# diretamente pelo app na aba Configurações.
#
# Se preenchido aqui, os valores serão usados
# como padrão ao abrir o app pela primeira vez.
# ============================================

# Strava API
client_id = "SEU_CLIENT_ID"
client_secret = "SEU_CLIENT_SECRET"

# Anthropic API
anthropic_key = "sk-ant-..."

# URL do app no Streamlit Cloud (preencher após deploy)
redirect_uri = "https://SEU-APP.streamlit.app"

# Perfil do atleta (valores padrão)
[athlete]
nome = "Seu Nome"
nivel = "intermediário"
objetivo = "Completar meia maratona"
treinos_semana = 3
fc_max = 185
fc_repouso = 50
pace_limiar = "5:30"
dias_descanso = [0, 2]
